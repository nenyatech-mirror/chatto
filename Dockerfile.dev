FROM golang:1.26

RUN apt-get update && apt-get install -y --no-install-recommends xz-utils ffmpeg && rm -rf /var/lib/apt/lists/*

ARG WATCHEXEC_VERSION=2.3.2
ARG TARGETARCH
RUN set -eux; \
    case "$TARGETARCH" in \
      amd64) arch=x86_64 ;; \
      arm64) arch=aarch64 ;; \
      *) echo "unsupported arch: $TARGETARCH" >&2; exit 1 ;; \
    esac; \
    url="https://github.com/watchexec/watchexec/releases/download/v${WATCHEXEC_VERSION}/watchexec-${WATCHEXEC_VERSION}-${arch}-unknown-linux-gnu.tar.xz"; \
    curl -fsSL "$url" -o /tmp/watchexec.tar.xz; \
    tar -xJf /tmp/watchexec.tar.xz -C /tmp; \
    mv /tmp/watchexec-*/watchexec /usr/local/bin/watchexec; \
    rm -rf /tmp/watchexec*

WORKDIR /app

# Bake in the cli/ tree so the image can run standalone (e.g. under Tilt
# in Kubernetes, where there's no Compose bind-mount). When used under
# Compose this is overlaid by the bind-mount and adds no runtime cost.
COPY cli ./cli
