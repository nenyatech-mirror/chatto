{
  "name": "chatto-frontend",
  "private": true,
  "version": "0.3.7",
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "codegen": "graphql-codegen",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/client-preset": "^5.3.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@iconify/json": "^2.2.472",
    "@iconify/tailwind4": "^1.2.3",
    "@parcel/watcher": "^2.5.6",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/sveltekit": "^10.3.6",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@tiptap/core": "^3.23.2",
    "@tiptap/extension-code-block-lowlight": "3.23.2",
    "@tiptap/extension-link": "3.23.2",
    "@tiptap/extension-placeholder": "^3.23.2",
    "@tiptap/markdown": "3.23.2",
    "@tiptap/pm": "^3.23.2",
    "@tiptap/starter-kit": "^3.23.2",
    "@types/linkify-it": "^5.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.19",
    "@urql/svelte": "^5.0.0",
    "@vitest/browser": "^4.1.6",
    "@vitest/browser-playwright": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.6",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^16.5.0",
    "graphql": "^16.14.0",
    "graphql-ws": "^6.0.8",
    "highlight.js": "^11.11.1",
    "lowlight": "3.3.0",
    "markdown-it": "^14.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "sharp": "^0.34.5",
    "storybook": "^10.3.6",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-dnd-action": "^0.9.69",
    "svelte2tsx": "^0.7.55",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "urql": "^5.0.2",
    "virtua": "^0.48.8",
    "vite": "^7.3.3",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.6",
    "vitest-browser-svelte": "^2.1.1",
    "wonka": "^6.3.6",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide"
    ]
  },
  "dependencies": {
    "gemoji": "^8.1.0",
    "heic2any": "^0.0.4",
    "linkify-it": "^5.0.0",
    "livekit-client": "^2.18.10",
    "tlds": "^1.261.0",
    "vidstack": "^1.12.13"
  }
}
