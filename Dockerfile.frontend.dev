# Dev-shell image for Tilt-based local Kubernetes development.
# Source is live-synced into running pods by Tilt — no need to rebuild on
# every code change. The umbrella's Tiltfile builds this via docker_build().

FROM node:22-alpine
RUN corepack enable pnpm
WORKDIR /app

# Layer 1: deps (cached unless lockfile changes)
COPY package.json pnpm-lock.yaml ./
RUN pnpm config set store-dir /pnpm-store && pnpm install --frozen-lockfile

# Layer 2: source (live-updated by Tilt afterwards, no rebuild needed)
COPY . .
