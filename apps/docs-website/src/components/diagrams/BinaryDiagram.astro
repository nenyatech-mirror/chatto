---
import { baseStyles } from './styles';
import Box from './Box.astro';
import Region from './Region.astro';
import Dot from './Dot.astro';
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 230" fill="none">
  <style set:html={baseStyles} />

  <Region x={215} y={20} w={370} h={185} label="SINGLE PROCESS" />

  <Box type="browser" x={16} y={75} label="Browser" sublabel="SvelteKit SPA" />
  <Box type="chatto" x={245} y={55} w={310} h={90} label="Chatto" sublabel="GraphQL · WebSocket · TLS" port=":443" />

  <!-- Embedded NATS (nested inside Chatto) -->
  <rect class="box box-nats" x="455" y="65" width="90" height="70" rx="8" ry="8" stroke-width="1"/>
  <text class="label" x="500" y="95" text-anchor="middle" style="font-size: 11px;">NATS</text>
  <text class="sublabel" x="500" y="109" text-anchor="middle" style="font-size: 9px;">embedded</text>

  <!-- Data directory -->
  <text class="sublabel" x="400" y="175" text-anchor="middle">./data/</text>
  <path class="conn" d="M400,145 L400,165" stroke-dasharray="4 3"/>

  <!-- Browser → Chatto -->
  <path id="p-browser-chatto" class="conn" d="M156,105 L243,105"/>
  <text class="proto" x="200" y="98" text-anchor="middle">HTTPS</text>
  <text class="proto" x="200" y="120" text-anchor="middle">WSS</text>

  <Dot path="p-browser-chatto" r={3} dur="1.4s" />
  <Dot path="p-browser-chatto" r={3} dur="1.4s" begin="0.7s" />
</svg>
