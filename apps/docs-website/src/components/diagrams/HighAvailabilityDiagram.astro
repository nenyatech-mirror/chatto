---
import { baseStyles } from './styles';
import Box from './Box.astro';
import Region from './Region.astro';
import Dot from './Dot.astro';
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 700 300" fill="none">
  <style set:html={baseStyles} />

  <Region x={300} y={15} w={385} h={270} label="NATS CLUSTER (RAFT CONSENSUS)" />

  <Box type="chatto" x={16} y={50} label="Chatto" sublabel="replica 1" />
  <Box type="chatto" x={16} y={195} label="Chatto" sublabel="replica 2" />

  <Box type="nats-leader" x={325} y={50} w={130} label="nats-1" sublabel="leader" />
  <Box type="nats" x={325} y={195} w={130} label="nats-2" sublabel="follower" />
  <Box type="nats" x={535} y={122} w={130} label="nats-3" sublabel="follower" />

  <text class="proto" x="510" y="82" text-anchor="middle">replication</text>

  <!-- Connections: Chatto ↔ NATS (dual lines) -->
  <path id="p-c1-nats" class="conn" d="M156,74 L323,74"/>
  <path id="p-nats-c1" class="conn" d="M323,80 L156,80"/>
  <path id="p-c2-nats" class="conn" d="M156,219 L323,219"/>
  <path id="p-nats-c2" class="conn" d="M323,225 L156,225"/>

  <!-- Replication between NATS nodes -->
  <path id="p-n1-n2" class="conn-repl" d="M390,105 L390,193"/>
  <path id="p-n1-n3" class="conn-repl" d="M455,90 L533,135"/>
  <path id="p-n2-n3" class="conn-repl" d="M455,210 L533,165"/>

  <!-- Chatto ↔ NATS: staggered with varied timing -->
  <Dot path="p-c1-nats" color="blue" dur="1.7s" />
  <Dot path="p-c1-nats" color="blue" r={2} dur="2.3s" begin="0.9s" opacity={0.6} />
  <Dot path="p-nats-c1" color="blue" dur="1.9s" begin="0.4s" />
  <Dot path="p-nats-c1" color="blue" r={2} dur="1.5s" begin="1.3s" opacity={0.6} />

  <Dot path="p-c2-nats" color="blue" dur="2.1s" begin="0.2s" />
  <Dot path="p-c2-nats" color="blue" r={2} dur="1.6s" begin="1.1s" opacity={0.6} />
  <Dot path="p-nats-c2" color="blue" dur="1.8s" begin="0.7s" />
  <Dot path="p-nats-c2" color="blue" r={2} dur="2.5s" begin="1.6s" opacity={0.6} />

  <!-- NATS replication -->
  <Dot path="p-n1-n2" color="repl" r={2} bounce dur="1.8s" />
  <Dot path="p-n1-n3" color="repl" r={2} bounce dur="2.2s" begin="0.3s" />
  <Dot path="p-n2-n3" color="repl" r={2} bounce dur="2s" begin="0.6s" />
</svg>
