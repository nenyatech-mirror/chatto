---
interface Props {
  name: string;
  toml: string;
  default?: string;
  required?: boolean;
}

const { name, toml, default: defaultValue, required } = Astro.props;
---

<div class="env-var">
  <div class="env-var-header">
    <code class="env-var-name">{name}</code>
    <div class="env-var-badges">
      {required && <span class="env-var-badge required">required</span>}
      {defaultValue && <span class="env-var-badge default">{defaultValue}</span>}
    </div>
  </div>
  <div class="env-var-meta">
    <code>{toml}</code>
  </div>
  <div class="env-var-body">
    <slot />
  </div>
</div>

<style>
  .env-var {
    padding: 0.875rem 1rem;
    border-radius: 0.5rem;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border: 1px solid var(--sl-color-gray-5);
    margin-bottom: 0.75rem;
  }

  .env-var-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .env-var-name {
    font-weight: 600;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-white);
    background: none;
    padding: 0;
  }

  .env-var-badges {
    display: flex;
    gap: 0.375rem;
  }

  .env-var-badge {
    font-size: var(--sl-text-xs);
    padding: 0.125rem 0.5rem;
    border-radius: 1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .env-var-badge.required {
    background: var(--sl-color-orange-low);
    color: var(--sl-color-orange-high);
  }

  .env-var-badge.default {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
  }

  .env-var-meta {
    margin-top: 0.25rem;
  }

  .env-var-meta code {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    background: none;
    padding: 0;
  }

  .env-var-body {
    margin-top: 0.5rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }
</style>
