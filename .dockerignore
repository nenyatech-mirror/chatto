# Ignore everything by default
*

# Frontend source needed for the SvelteKit build stage in Dockerfile.compose
# (and Dockerfile.frontend's production frontend build).
!frontend/package.json
!frontend/pnpm-lock.yaml
!frontend/pnpm-workspace.yaml
!frontend/.npmrc
!frontend/src/
!frontend/static/
!frontend/svelte.config.js
!frontend/tsconfig.json
!frontend/vite.config.ts
!frontend/nginx.conf

# Backend source needed for the Go build stage (and Dockerfile.dev under Tilt).
!cli/
cli/data/
cli/bin/

# Entrypoint for the release image (Dockerfile.goreleaser).
!docker-entrypoint.sh
